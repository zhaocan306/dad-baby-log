<view class="page">
  <custom-navbar showBack="{{true}}" bindback="goBack" />
  <scroll-view class="inner-padding" scroll-y>
    <view class="header-section">
      <view class="title-text-group">
        <text class="title-main">疫苗日程</text>
        <text class="title-sub">全国通用规则，支持新增和删除里程碑卡片</text>
      </view>
    </view>
    <view class="card-settings shadow-soft">
      <text class="settings-title">接种计划设置</text>
      <text class="settings-desc">默认按全国通用规则生成里程碑。你可以按需要新增自定义卡片，或删除不需要的卡片。</text>
      <view class="switch-row">
        <text class="switch-label">显示自费推荐</text>
        <image class="switch-img" src="/static/switch-active.png" mode="aspectFit" />
      </view>
    </view>
    <view class="filter-tabs-row">
      <view class="tab-capsule active-tab"><text class="capsule-text text-white">全部</text></view>
      <view class="tab-capsule"><text class="capsule-text">免费</text></view>
      <view class="tab-capsule"><text class="capsule-text">自费</text></view>
      <view class="tab-capsule"><text class="capsule-text">待确认</text></view>
    </view>
    <view class="grid-stats mb-6">
      <view class="stat-block bg-green-light"><text class="stat-label text-green">免费</text><text class="stat-count text-green">22</text></view>
      <view class="stat-block bg-poop-light"><text class="stat-label text-poop">自费</text><text class="stat-count text-poop">29</text></view>
      <view class="stat-block bg-blue-light"><text class="stat-label text-blue">待确认</text><text class="stat-count text-blue">0</text></view>
      <view class="stat-block bg-rose-light"><text class="stat-label text-rose">逾期</text><text class="stat-count text-rose">1</text></view>
      <view class="stat-block bg-milk-light"><text class="stat-label text-milk">完成</text><text class="stat-count text-milk">10</text></view>
    </view>
    <view class="milestone-section">
      <view class="milestone-header">
        <text class="section-title">接种里程碑</text>
        <view class="btn-add-milestone">
          <image class="add-icon" src="/static/icon-add-purple.png" mode="aspectFit" />
          <text class="add-text">新增</text>
        </view>
      </view>
      <view class="milestone-list">
        <view class="milestone-card shadow-soft mb-4" wx:for="{{milestones}}" wx:key="id" wx:for-item="m">
          <view class="card-main-row">
            <view class="card-left-info">
              <image class="vaccine-icon" src="/static/icon-vaccine-needle.png" mode="aspectFit" />
              <view class="vaccine-meta">
                <text class="vaccine-name">{{m.vaccine_name}} · {{m.dose}}</text>
                <text class="vaccine-desc">{{m.age_month}}月龄</text>
                <text class="vaccine-desc">状态: {{m.status}}</text>
              </view>
            </view>
            <view class="card-right-badges">
              <text class="status-badge bg-green-badge text-green-badge">{{m.status === 'done' ? '已完成' : m.status === 'booked' ? '已预约' : '待确认'}}</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
