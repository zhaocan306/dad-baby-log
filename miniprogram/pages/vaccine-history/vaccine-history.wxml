<view class="page">
  <custom-navbar showBack="{{true}}" bindback="goBack" />
  <scroll-view class="inner-padding" scroll-y>
    <view class="header-section">
      <view class="title-text-group">
        <text class="title-main">疫苗历史</text>
        <text class="title-sub">查看已接种、待预约和留观记录</text>
      </view>
      <view class="time-badge">
        <text class="badge-text">7天</text>
      </view>
    </view>
    <view class="card-vaccine-summary shadow-soft">
      <view class="card-header">
        <view class="title-with-icon">
          <image class="summary-card-icon" src="/static/icon-vaccine-summary.png" mode="aspectFit" />
          <text class="card-title">疫苗进度</text>
        </view>
        <view class="status-badge">
          <text class="status-badge-text">还剩2天</text>
        </view>
      </view>
      <view class="stats-row">
        <view class="stat-item"><text class="stat-number">{{stats.done || "0"}}针</text><text class="stat-label">已完成</text></view>
        <view class="stat-item"><text class="stat-number">{{stats.booked || "0"}}针</text><text class="stat-label">预约中</text></view>
        <view class="stat-item"><text class="stat-number">0次</text><text class="stat-label">不适</text></view>
      </view>
    </view>
    <view class="recent-records-section">
      <view class="records-header">
        <text class="section-title">最近记录</text>
        <text class="sort-text">按日期</text>
      </view>
      <view class="records-list-container shadow-mini">
        <view class="record-item" wx:for="{{records}}" wx:key="id" wx:for-item="r">
          <view class="record-left">
            <image class="record-type-icon" src="/static/list-icon-vaccine-done.png" mode="aspectFit" />
            <view class="record-meta">
              <text class="record-name">{{r.name}}</text>
              <text class="record-desc">{{r.note}}</text>
            </view>
          </view>
          <text class="record-time">{{r._date}}</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>