<view class="page">
  <custom-navbar showBack="{{true}}" bindback="goBack" />
  <scroll-view class="inner-padding" scroll-y>
    <view class="header-section">
      <view class="title-text-group">
        <text class="title-main">渚夸究鍘嗗彶</text>
        <text class="title-sub">璁板綍娆℃暟銆侀鑹层€佸舰鎬佸拰灏垮竷鎯呭喌</text>
      </view>
      <view class="time-badge">
        <text class="badge-text">7澶?/text>
      </view>
    </view>
    <view class="card-poop-summary shadow-soft">
      <view class="card-header">
        <view class="title-with-icon">
          <image class="summary-card-icon" src="/static/icon-poop-smile.png" mode="aspectFit" />
          <text class="card-title">鏈懆渚夸究</text>
        </view>
        <view class="status-badge">
          <text class="status-badge-text">姝ｅ父</text>
        </view>
      </view>
      <view class="stats-row">
        <view class="stat-item"><text class="stat-number">{{stats.total}}娆?/text><text class="stat-label">鎬绘鏁?/text></view>
        <view class="stat-item"><text class="stat-number">{{stats.amount || "涓?}}閲?/text><text class="stat-label">甯歌閲?/text></view>
        <view class="stat-item"><text class="stat-number">{{stats.total || "0"}娆?/text><text class="stat-label">閲戦粍鑹?/text></view>
      </view>
    </view>
    <view class="recent-records-section">
      <view class="records-header">
        <text class="section-title">鏈€杩戣褰?/text>
        <text class="sort-text">鎸夋棩鏈?/text>
      </view>
      <view class="records-list-container shadow-mini">
        <view class="record-item" wx:for="{{records}}" wx:key="id" wx:for-item="r">
          <view class="record-left">
            <image class="record-type-icon" src="/static/list-icon-poop-1.png" mode="aspectFit" />
            <view class="record-meta">
              <text class="record-name">{{r.name}}</text>
              <text class="record-desc">{{r.note}}</text>
            </view>
          </view>
          <text class="record-time">{{r._time}}</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
