<view class="page">
  <custom-navbar showBack="{{true}}" bindback="goBack" />
  <scroll-view class="inner-padding" scroll-y>
    <view class="header-section">
      <view class="title-text-group">
        <text class="title-main">喝奶历史</text>
        <text class="title-sub">按天查看奶量、方式和间隔</text>
      </view>
      <view class="time-badge">
        <text class="badge-text">7天</text>
      </view>
    </view>
    <view class="card-milk-summary shadow-soft">
      <view class="card-header">
        <view class="title-with-icon">
          <image class="summary-card-icon" src="/static/icon-milk.png" mode="aspectFit" />
          <text class="card-title">本周总奶量</text>
        </view>
        <view class="status-badge">
          <text class="status-badge-text">+6%</text>
        </view>
      </view>
      <view class="stats-row">
        <view class="stat-item"><text class="stat-number">{{stats.total}}L</text><text class="stat-label">总量</text></view>
        <view class="stat-item"><text class="stat-number">{{stats.dailyAvg}}ml</text><text class="stat-label">日均</text></view>
        <view class="stat-item"><text class="stat-number">{{stats.count}}次</text><text class="stat-label">喂养</text></view>
      </view>
    </view>
    <view class="recent-records-section">
      <view class="records-header">
        <text class="section-title">最近记录</text>
        <text class="sort-text">按日期</text>
      </view>
      <view class="records-list-container shadow-mini">
        <view class="record-item" wx:for="{{records}}" wx:key="id" wx:for-item="r">
          <view class="record-left">
            <image class="record-type-icon" src="/static/list-icon-milk-1.png" mode="aspectFit" />
            <view class="record-meta">
              <text class="record-name">{{r.name}}</text>
              <text class="record-desc">{{r.note}}</text>
            </view>
          </view>
          <text class="record-time">{{r.created_at?.slice(11, 16) || ""}}</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
